{% extends 'base.html.twig' %}

{% block title %}Plomberie - Fort Intervention{% endblock %}

{% block body %}
    <style>
        /* --- STYLES HERO --- */
        .hero-plomberie {
            position: relative;
            padding: 100px 0 80px;
            overflow: hidden;
            background-color: #1a1d20;
            color: white;
        }
        .hero-background {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('{{ asset('images/plomberie.webp') }}');
            background-size: cover;
            background-position: center;
            opacity: 0.2;
            filter: blur(4px);
            z-index: 1;
        }
        .hero-plomberie::after {
            content: '';
            position: absolute;
            bottom: -50px;
            left: 0;
            width: 100%;
            height: 100px;
            background-color: var(--bs-body-bg);
            transform: skewY(-2deg);
            z-index: 2;
        }
        .hero-content { position: relative; z-index: 3; }

        /* --- ENCART URGENCE --- */
        .emergency-box { background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); color: white; border-radius: 20px; padding: 40px; box-shadow: 0 20px 40px rgba(220, 38, 38, 0.25); position: relative; overflow: hidden; margin-top: -30px; z-index: 10; border: 1px solid rgba(255,255,255,0.2); }
        .emergency-box::before { content: '\f071'; font-family: 'Font Awesome 6 Free'; font-weight: 900; position: absolute; right: -20px; bottom: -30px; font-size: 180px; opacity: 0.08; transform: rotate(-15deg); pointer-events: none; }
        .pulse-icon { animation: pulseWarning 2s infinite; }
        @keyframes pulseWarning { 0% { opacity: 1; transform: scale(1); } 50% { opacity: 0.6; transform: scale(1.1); } 100% { opacity: 1; transform: scale(1); } }

        /* --- AUTRES SECTIONS --- */
        .feature-icon-box { width: 60px; height: 60px; display: inline-flex; align-items: center; justify-content: center; border-radius: 16px; background: rgba(var(--bs-primary-rgb), 0.1); color: var(--bs-primary); font-size: 28px; margin-bottom: 1.5rem; transition: transform 0.3s ease; }
        .feature-icon-box:hover { transform: scale(1.1) rotate(5deg); }

        .hover-lift { transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s ease; border-radius: 15px; }
        .hover-lift:hover { transform: translateY(-8px); box-shadow: 0 15px 30px rgba(0,0,0,0.15); z-index: 2; position: relative; }

        .cross-img { height: 100%; min-height: 400px; object-fit: cover; border-radius: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.1); }

        /* --- SLIDER AVANT / APRÈS --- */
        .ba-container { position: relative; width: 100%; height: 400px; overflow: hidden; border-radius: 15px; user-select: none; background-color: var(--bs-tertiary-bg); box-shadow: 0 10px 30px rgba(0,0,0,0.08); border: 1px solid var(--bs-border-color); }
        .ba-image { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-size: contain; background-repeat: no-repeat; background-position: center; pointer-events: none; }
        .ba-after { z-index: 1; filter: contrast(1.05); }
        .ba-before { z-index: 2; width: 100%; height: 100%; border-right: none; clip-path: inset(0 50% 0 0); }
        .ba-separator { position: absolute; z-index: 3; top: 0; bottom: 0; width: 4px; background: #fff; left: 50%; transform: translateX(-50%); box-shadow: 0 0 15px rgba(0,0,0,0.5); pointer-events: none; }
        .ba-slider { position: absolute; z-index: 4; top: 0; bottom: 0; left: 50%; width: 60px; margin-left: -30px; cursor: ew-resize; display: flex; align-items: center; justify-content: center; }
        .ba-handle { width: 50px; height: 50px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 20px rgba(0,0,0,0.3); color: var(--bs-primary); pointer-events: none; transition: transform 0.2s, box-shadow 0.2s; border: 2px solid var(--bs-primary); font-size: 1.2rem; }
        .ba-slider:hover .ba-handle { transform: scale(1.15); box-shadow: 0 6px 25px rgba(0,0,0,0.4); }
        .ba-label { position: absolute; bottom: 15px; padding: 6px 18px; background: rgba(0,0,0,0.6); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); color: white; border-radius: 30px; font-size: 12px; font-weight: 800; letter-spacing: 1.5px; z-index: 5; pointer-events: none; text-transform: uppercase; border: 1px solid rgba(255,255,255,0.2); }
        .ba-label-before { left: 15px; }
        .ba-label-after { right: 15px; }

        /* --- CARTES MATÉRIEL --- */
        .product-card { border: 1px solid var(--bs-border-color); border-radius: 15px; text-align: center; padding: 20px; background: var(--bs-body-bg); transition: box-shadow 0.3s, transform 0.3s; height: 100%; }
        .product-card:hover { box-shadow: 0 10px 20px rgba(0,0,0,0.1); transform: translateY(-5px); }
        .product-img { width: 100%; height: 180px; object-fit: cover; border-radius: 10px; margin-bottom: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
    </style>

    {# --- HERO SECTION --- #}
    <div class="hero-plomberie text-center">
        <div class="hero-background"></div>
        <div class="container hero-content">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <span class="badge bg-danger text-white px-3 py-2 mb-3 fs-6 pulse-icon">Urgence 24/7 - Plomberie</span>
                    <h1 class="display-3 fw-bold mb-4">Dépannage & Installation</h1>
                    <p class="lead opacity-75 mb-3">Une fuite d'eau, un chauffe-eau en panne ou des canalisations bouchées ? Nos artisans interviennent pour stopper les dégâts et réparer durablement vos installations.</p>
                    <p class="text-light opacity-50 mb-5" style="font-size: 1.1rem;">
                        Nous utilisons des techniques de pointe pour la recherche de fuites non-destructive et le débouchage haute pression. Une intervention rapide, propre et garantie.
                    </p>
                    <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                        <a href="tel:0326970086" class="btn btn-primary btn-lg rounded-pill px-4 fw-bold shadow-lg d-flex align-items-center justify-content-center">
                            <i class="fa-solid fa-phone-volume fa-shake me-2"></i> Urgence : 03 26 97 00 86
                        </a>
                        <a href="{{ path('app_planning') }}" class="btn btn-outline-light btn-lg rounded-pill px-4 fw-bold shadow">
                            <i class="fa-solid fa-calendar me-2"></i> Prendre RDV
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# --- ENCART URGENCE SUPERPOSÉ --- #}
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="emergency-box">
                    <div class="row align-items-center position-relative z-1">
                        <div class="col-md-9 text-center text-md-start">
                            <h3 class="fw-bold mb-3"><i class="fa-solid fa-triangle-exclamation me-2 pulse-icon text-warning"></i>Urgence Fuite : En attendant notre arrivée</h3>
                            <p class="mb-2 fs-5">Pour limiter les dégâts des eaux : <strong>coupez l'arrivée d'eau générale immédiatement !</strong></p>
                            <p class="mb-0 opacity-75 small">La vanne se trouve généralement près de votre compteur d'eau (dans les toilettes, sous l'évier, ou sur le palier). Tournez-la dans le sens des aiguilles d'une montre.</p>
                        </div>
                        <div class="col-md-3 text-center mt-4 mt-md-0 d-none d-md-block">
                            <i class="fa-solid fa-faucet-drip fa-5x opacity-50 text-white"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container py-5 mt-4">

        {# --- SECTION : RECHERCHE DE FUITE --- #}
        <div class="row align-items-center g-5 mb-5 pb-5 border-bottom">
            <div class="col-lg-6 order-2 order-lg-1">
                <div class="feature-icon-box shadow-sm">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </div>
                <h2 class="fw-bold mb-4 display-6">Recherche de Fuite & Tuyauterie</h2>
                <p class="text-muted fs-5 mb-4">
                    Infiltration d'eau invisible ? Nous utilisons des techniques de pointe (caméras endoscopiques, détecteurs d'humidité) pour localiser la fuite sans casser vos murs. Ensuite, nous réparons la section endommagée.
                </p>
                <ul class="list-unstyled mt-4 text-muted fs-6">
                    <li class="mb-3 d-flex align-items-center bg-body-tertiary p-3 rounded-3 shadow-sm">
                        <i class="fa-solid fa-circle-check text-primary fs-4 me-3"></i>
                        <span>Recherche non-destructive garantie</span>
                    </li>
                    <li class="mb-3 d-flex align-items-center bg-body-tertiary p-3 rounded-3 shadow-sm">
                        <i class="fa-solid fa-circle-check text-primary fs-4 me-3"></i>
                        <span>Réparation sur tous matériaux (Cuivre, PER, Multicouche)</span>
                    </li>
                </ul>
            </div>
            <div class="col-lg-6 order-1 order-lg-2">
                <img src="{{ asset('images/fuite.jpeg') }}" class="cross-img w-100 hover-lift" alt="Recherche de fuite">
            </div>
        </div>

        {# --- SECTION : DÉBOUCHAGE --- #}
        <div class="row align-items-center g-5 mb-5 pb-5 border-bottom">
            <div class="col-lg-6">
                <img src="{{ asset('images/debouche.webp') }}" class="cross-img w-100 hover-lift" alt="Débouchage">
            </div>
            <div class="col-lg-6">
                <div class="feature-icon-box shadow-sm">
                    <i class="fa-solid fa-sink"></i>
                </div>
                <h2 class="fw-bold mb-4 display-6">Débouchage & Sanitaires</h2>
                <p class="text-muted fs-5 mb-4">
                    Évier bouché, eau qui remonte, ou chasse d'eau qui fuit ? Nous intervenons avec des furets professionnels ou des pompes à haute pression pour désengorger vos canalisations rapidement.
                </p>
                <ul class="list-unstyled mt-4 text-muted fs-6">
                    <li class="mb-3 d-flex align-items-center bg-body-tertiary p-3 rounded-3 shadow-sm">
                        <i class="fa-solid fa-circle-check text-primary fs-4 me-3"></i>
                        <span>Débouchage mécanique sans produits chimiques</span>
                    </li>
                    <li class="mb-3 d-flex align-items-center bg-body-tertiary p-3 rounded-3 shadow-sm">
                        <i class="fa-solid fa-circle-check text-primary fs-4 me-3"></i>
                        <span>Remplacement de mécanisme WC et robinetterie</span>
                    </li>
                </ul>
            </div>
        </div>

        {# --- SECTION AVANT / APRES AVEC LA BOUCLE EASYADMIN --- #}
        <div class="pt-5 pb-5 border-bottom">
            <div class="text-center mb-5">
                <span class="text-primary fw-bold text-uppercase tracking-wide small">Nos Interventions</span>
                <h2 class="fw-bold display-6 mb-3">Rénovation & Réparation en images</h2>
                <p class="text-muted mx-auto" style="max-width: 600px;">
                    Glissez le curseur pour voir la différence. Nous transformons vos installations défectueuses en équipements fiables et durables.
                </p>
            </div>

            <div class="row g-5 justify-content-center">
                {% for real in realisations %}
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-body hover-lift">
                            <div class="ba-container" id="ba-plumb-{{ real.id }}">
                                <div class="ba-image ba-after" style="background-image: url('{{ asset('uploads/realisations/' ~ real.imageAfter) }}');"></div>

                                {% if real.imageBefore %}
                                    <div class="ba-image ba-before" style="background-image: url('{{ asset('uploads/realisations/' ~ real.imageBefore) }}');"></div>
                                    <div class="ba-separator"></div>
                                    <div class="ba-label ba-label-before">AVANT</div>
                                    <div class="ba-slider"><div class="ba-handle"><i class="fa-solid fa-arrows-left-right"></i></div></div>
                                {% endif %}

                                <div class="ba-label ba-label-after">APRÈS</div>
                            </div>
                        </div>
                        <h5 class="fw-bold text-center mt-4">{{ real.title }}</h5>
                        {% if real.description %}
                            <p class="small text-muted text-center">{{ real.description }}</p>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="col-12 text-center text-muted">
                        <p>Aucune réalisation ajoutée pour la catégorie Plomberie.</p>
                    </div>
                {% endfor %}
            </div>
        </div>

        {# --- CARTES OUTILS ET ÉQUIPEMENTS --- #}
        <div class="py-5">
            <h2 class="fw-bold text-center mb-5 display-6">Notre Équipement & Savoir-Faire</h2>
            <div class="row g-4 justify-content-center">

                <div class="col-lg-4 col-md-6">
                    <div class="product-card">
                        <img src="{{ asset('images/outil.webp') }}" alt="Outillage professionnel" class="product-img">
                        <h5 class="fw-bold">Outillage de Précision</h5>
                        <p class="small text-muted mb-0">Matériel professionnel de pointe pour des interventions propres, sans dommage pour vos murs et vos sols.</p>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="product-card">
                        <img src="{{ asset('images/raccord.webp') }}" alt="Raccords laiton" class="product-img">
                        <h5 class="fw-bold">Raccords Laiton</h5>
                        <p class="small text-muted mb-0">Nous utilisons exclusivement de la visserie et des raccords haute durabilité pour prévenir les fuites futures.</p>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="product-card">
                        <img src="{{ asset('images/chauffe.webp') }}" alt="Chauffe eau" class="product-img">
                        <h5 class="fw-bold">Cumulus & Chauffe-eau</h5>
                        <p class="small text-muted mb-0">Diagnostic, réparation des résistances ou remplacement complet par des équipements basse consommation.</p>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="product-card">
                        <img src="{{ asset('images/joint.webp') }}" alt="Joint étanchéité" class="product-img">
                        <h5 class="fw-bold">Joints & Étanchéité</h5>
                        <p class="small text-muted mb-0">Réfection complète de vos joints de sanitaires et de tuyauteries pour stopper les infiltrations.</p>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="product-card">
                        <img src="{{ asset('images/debouchage.webp') }}" alt="Débouchage pompe" class="product-img">
                        <h5 class="fw-bold">Pompe de Débouchage</h5>
                        <p class="small text-muted mb-0">Désengorgement à haute pression de vos siphons et canalisations, méthode 100% écologique.</p>
                    </div>
                </div>

            </div>

            <div class="text-center mt-5 pt-4">
                <a href="{{ path('app_planning') }}" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow-lg hover-lift d-inline-flex align-items-center">
                    Planifier une réparation <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>

    </div>

    {# SCRIPT POUR LES SLIDERS AVANT/APRES #}
    <script>
        document.addEventListener('turbo:load', () => {
            const containers = document.querySelectorAll('.ba-container');
            containers.forEach(container => {
                const before = container.querySelector('.ba-before');
                const separator = container.querySelector('.ba-separator');
                const slider = container.querySelector('.ba-slider');

                if(!slider) return;

                let isDragging = false;

                slider.addEventListener('dragstart', (e) => e.preventDefault());

                const move = (e) => {
                    if (!isDragging) return;
                    let rect = container.getBoundingClientRect();
                    let x = (e.pageX || e.touches[0].pageX) - rect.left;
                    let percent = (x / rect.width) * 100;
                    if (percent < 0) percent = 0; if (percent > 100) percent = 100;
                    before.style.clipPath = `inset(0 ${100 - percent}% 0 0)`;
                    separator.style.left = percent + '%'; slider.style.left = percent + '%';
                };

                slider.onmousedown = (e) => { isDragging = true; e.preventDefault(); };
                window.addEventListener('mouseup', () => isDragging = false);
                window.addEventListener('mousemove', move);

                slider.ontouchstart = () => { isDragging = true; };
                window.addEventListener('touchend', () => isDragging = false);
                window.addEventListener('touchmove', move);
            });
        });
    </script>
{% endblock %}
