{% extends 'base.html.twig' %}

{% block title %}Menuiserie - Fort Intervention{% endblock %}

{% block body %}
    <style>
        /* --- STYLES HERO --- */
        .hero-menuiserie {
            position: relative;
            padding: 100px 0 80px;
            overflow: hidden;
            background-color: #1a1d20;
            color: white;
        }
        .hero-background {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('{{ asset('images/menuiserie.webp') }}');
            background-size: cover;
            background-position: center;
            opacity: 0.2;
            filter: blur(4px);
            z-index: 1;
        }
        .hero-menuiserie::after {
            content: '';
            position: absolute;
            bottom: -50px;
            left: 0;
            width: 100%;
            height: 100px;
            background-color: var(--bs-body-bg);
            transform: skewY(-2deg);
            z-index: 2;
        }
        .hero-content { position: relative; z-index: 3; }

        /* --- AUTRES SECTIONS --- */
        .feature-icon-box { width: 60px; height: 60px; display: inline-flex; align-items: center; justify-content: center; border-radius: 16px; background: rgba(var(--bs-primary-rgb), 0.1); color: var(--bs-primary); font-size: 28px; margin-bottom: 1.5rem; transition: transform 0.3s ease; }
        .feature-icon-box:hover { transform: scale(1.1) rotate(-5deg); }

        .carousel-img-custom { height: 450px; object-fit: cover; border-radius: 15px; }
        .carousel-shadow { box-shadow: 0 15px 35px rgba(0,0,0,0.1); }
        [data-bs-theme="dark"] .carousel-shadow { box-shadow: 0 15px 35px rgba(0,0,0,0.4); }

        /* --- SECTION A À Z (ÉTAPES) --- */
        .step-card { border: 1px solid var(--bs-border-color); background: var(--bs-body-bg); border-radius: 15px; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease; height: 100%; }
        .step-card:hover { transform: translateY(-8px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); }
        .step-img-wrap { position: relative; overflow: hidden; }
        .step-img-wrap img { width: 100%; height: 200px; object-fit: cover; transition: transform 0.5s ease; }
        .step-card:hover .step-img-wrap img { transform: scale(1.05); }
        .step-badge { position: absolute; top: 15px; left: 15px; background: var(--bs-primary); color: white; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: bold; font-size: 1.2rem; box-shadow: 0 4px 10px rgba(0,0,0,0.3); z-index: 2; }

        /* --- DÉFILEMENT AUTOMATIQUE (MARQUEE) POUR LA GALERIE --- */
        .marquee-wrapper { display: flex; overflow: hidden; width: 100%; padding: 20px 0; }
        .marquee-content { display: flex; animation: scrollMarquee 30s linear infinite; }
        .marquee-content:hover { animation-play-state: paused; }
        @keyframes scrollMarquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
        .gallery-item-marquee { width: 350px; height: 280px; margin: 0 15px; border-radius: 15px; overflow: hidden; position: relative; cursor: pointer; box-shadow: 0 10px 20px rgba(0,0,0,0.1); flex-shrink: 0; }
        .gallery-item-marquee img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.25, 0.8, 0.25, 1); }
        .gallery-item-marquee:hover img { transform: scale(1.1); }
        .gallery-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(0,0,0,0.9), transparent); padding: 30px 20px 20px; color: white; opacity: 0; transition: opacity 0.3s ease, transform 0.3s ease; transform: translateY(10px); }
        .gallery-item-marquee:hover .gallery-overlay { opacity: 1; transform: translateY(0); }

        /* --- SLIDER AVANT / APRÈS --- */
        /* Images en mode 'contain' et fond 'tertiary' pour ne pas zoomer ou couper les photos */
        .ba-container { position: relative; width: 100%; height: 400px; overflow: hidden; border-radius: 15px; user-select: none; background-color: var(--bs-tertiary-bg); box-shadow: 0 10px 30px rgba(0,0,0,0.08); border: 1px solid var(--bs-border-color); }
        .ba-image { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-size: contain; background-repeat: no-repeat; background-position: center; pointer-events: none; }
        .ba-after { z-index: 1; filter: contrast(1.05); }
        .ba-before { z-index: 2; width: 100%; height: 100%; border-right: none; clip-path: inset(0 50% 0 0); }
        .ba-separator { position: absolute; z-index: 3; top: 0; bottom: 0; width: 4px; background: #fff; left: 50%; transform: translateX(-50%); box-shadow: 0 0 15px rgba(0,0,0,0.5); pointer-events: none; }
        .ba-slider { position: absolute; z-index: 4; top: 0; bottom: 0; left: 50%; width: 60px; margin-left: -30px; cursor: ew-resize; display: flex; align-items: center; justify-content: center; }
        .ba-handle { width: 50px; height: 50px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 20px rgba(0,0,0,0.3); color: var(--bs-primary); pointer-events: none; transition: transform 0.2s, box-shadow 0.2s; border: 2px solid var(--bs-primary); font-size: 1.2rem; }
        .ba-slider:hover .ba-handle { transform: scale(1.15); box-shadow: 0 6px 25px rgba(0,0,0,0.4); }
        .ba-label { position: absolute; bottom: 15px; padding: 6px 18px; background: rgba(0,0,0,0.6); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); color: white; border-radius: 30px; font-size: 12px; font-weight: 800; letter-spacing: 1.5px; z-index: 5; pointer-events: none; text-transform: uppercase; border: 1px solid rgba(255,255,255,0.2); }
        .ba-label-before { left: 15px; }
        .ba-label-after { right: 15px; }

        .hover-lift { transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s ease; border-radius: 15px; }
        .hover-lift:hover { transform: translateY(-8px); box-shadow: 0 15px 30px rgba(0,0,0,0.15); z-index: 2; position: relative; }
    </style>

