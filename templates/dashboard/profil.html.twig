{% extends 'base.html.twig' %}

{% block title %}Mon Profil - Fort Intervention{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-body p-4 p-md-5">

                        <div class="text-center mb-5">
                            <div class="position-relative d-inline-block mb-3">
                                {% if app.user.profilePicture %}
                                    <img src="{{ asset('uploads/profiles/' ~ app.user.profilePicture) }}" alt="Photo" class="rounded-circle shadow border border-4 border-white" style="width: 120px; height: 120px; object-fit: cover;">
                                {% else %}
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex justify-content-center align-items-center shadow border border-4 border-white" style="width: 120px; height: 120px;">
                                        <i class="fa-solid fa-user fs-1"></i>
                                    </div>
                                {% endif %}
                            </div>
                            <h3 class="fw-bold mb-1">{{ app.user.firstName }} {{ app.user.lastName }}</h3>
                            <p class="text-muted"><i class="fa-solid fa-envelope me-2"></i>{{ app.user.email }}</p>
                        </div>

                        {% for message in app.flashes('success') %}
                            <div class="alert alert-success rounded-3"><i class="fa-solid fa-check-circle me-2"></i> {{ message }}</div>
                        {% endfor %}
                        {% for message in app.flashes('danger') %}
                            <div class="alert alert-danger rounded-3"><i class="fa-solid fa-triangle-exclamation me-2"></i> {{ message }}</div>
                        {% endfor %}
                        <form action="{{ path('app_profil') }}" method="POST" enctype="multipart/form-data">
                            <input type="hidden" name="action" value="update_profile">

                            <h6 class="text-uppercase text-muted fw-bold mb-3 small border-bottom pb-2">Informations Personnelles</h6>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Prénom</label>
                                    <input type="text" name="firstName" class="form-control rounded-3" value="{{ app.user.firstName }}" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Nom</label>
                                    <input type="text" name="lastName" class="form-control rounded-3" value="{{ app.user.lastName }}" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold">Adresse Email</label>
                                <input type="email" name="email" class="form-control rounded-3" value="{{ app.user.email }}" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold">Téléphone</label>
                                <input type="text" name="phone" class="form-control rounded-3" value="{{ app.user.phone }}">
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold">Adresse</label>
                                <input type="text" name="address" class="form-control rounded-3 adresse-autocomplete" value="{{ app.user.address }}" autocomplete="off">
                            </div>

                            <h6 class="text-uppercase text-muted fw-bold mb-3 mt-4 small border-bottom pb-2">Modifier mon image</h6>
                            <div class="mb-4">
                                <input type="file" name="profilePicture" class="form-control rounded-3" accept="image/*">
                                <div class="form-text small">Formats acceptés : JPG, PNG, WEBP. Laissez vide pour conserver l'image actuelle.</div>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold shadow-sm mb-5">
                                Sauvegarder les modifications <i class="fa-solid fa-floppy-disk ms-2"></i>
                            </button>
                        </form>
                        <h6 class="text-uppercase text-muted fw-bold mb-3 small border-bottom pb-2">Sécurité & Mot de passe</h6>
                        <div class="bg-body-tertiary rounded-4 p-4 text-center border border-1 shadow-sm">
                            <i class="fa-solid fa-envelope-circle-check text-primary mb-3" style="font-size: 2.5rem; opacity: 0.8;"></i>
                            <p class="text-muted small px-3 mb-4">
                                Pour des raisons de sécurité, la modification de votre mot de passe nécessite une vérification. Nous vous enverrons un lien sécurisé à l'adresse <strong>{{ app.user.email }}</strong>.
                            </p>

                            <form method="post" action="{{ path('app_profil') }}">
                                <input type="hidden" name="action" value="send_reset_link">
                                <button type="submit" class="btn btn-outline-primary fw-bold px-4 py-2 rounded-pill shadow-sm">
                                    M'envoyer le lien de modification <i class="fa-solid fa-paper-plane ms-2"></i>
                                </button>
                            </form>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
