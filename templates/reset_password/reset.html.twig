{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe - Fort Intervention{% endblock %}

{% block body %}
    <div class="container py-5" style="min-height: 80vh; display: flex; align-items: center;">
        <div class="row justify-content-center w-100">
            <div class="col-md-8 col-lg-5">
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-body p-4 p-md-5 text-center">

                        {# Icône et Titre #}
                        <div class="mb-4">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 80px; height: 80px;">
                                <i class="fa-solid fa-lock fs-1"></i>
                            </div>
                            <h2 class="fw-bold">Nouveau mot de passe</h2>
                            <p class="text-muted small px-3">Veuillez saisir votre nouveau mot de passe ci-dessous. Il doit contenir au moins 6 caractères.</p>
                        </div>

                        {# Début du formulaire Symfony #}
                        {{ form_start(resetForm, {'attr': {'class': 'text-start'}}) }}

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted"><i class="fa-solid fa-key me-2"></i>Nouveau mot de passe</label>
                            {{ form_widget(resetForm.plainPassword.first, {
                                'attr': {
                                    'class': 'form-control form-control-lg rounded-3 fs-6',
                                    'placeholder': '••••••••'
                                }
                            }) }}
                            <div class="text-danger small mt-1">
                                {{ form_errors(resetForm.plainPassword.first) }}
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted"><i class="fa-solid fa-check-double me-2"></i>Confirmer le mot de passe</label>
                            {{ form_widget(resetForm.plainPassword.second, {
                                'attr': {
                                    'class': 'form-control form-control-lg rounded-3 fs-6',
                                    'placeholder': '••••••••'
                                }
                            }) }}
                            <div class="text-danger small mt-1">
                                {{ form_errors(resetForm.plainPassword.second) }}
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm fs-5 mt-2">
                            Enregistrer et me connecter <i class="fa-solid fa-right-to-bracket ms-2"></i>
                        </button>

                        {{ form_end(resetForm) }}

                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
