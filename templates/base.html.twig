<!DOCTYPE html>
<html lang="fr" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Fort Intervention{% endblock %}</title>

    <link rel="icon" type="image/webp" href="{{ asset('images/FortFav.jpg') }}">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/style.css') }}">

    {% block stylesheets %}{% endblock %}

    <script>
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-bs-theme', savedTheme);
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}

    <style>
        html, body { min-height: 100vh; margin: 0; }
        body { display: flex; flex-direction: column; background-color: var(--bs-body-bg); color: var(--bs-body-color); }
        main { flex: 1; }

        #page-loader { transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out; opacity: 0; visibility: hidden; z-index: 9999; background-color: var(--bs-body-bg); }
        #page-loader.is-loading { opacity: 0.9; visibility: visible; }

        .btn-theme-toggle { width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; }

        [data-bs-theme="dark"] .card { border: 1px solid rgba(255, 255, 255, 0.15) !important; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3) !important; background-color: #212529 !important; }
        [data-bs-theme="dark"] .navbar { background-color: #1a1d20 !important; border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important; }
        [data-bs-theme="dark"] footer { background-color: #111315 !important; border-top: 1px solid rgba(255, 255, 255, 0.05) !important; color: white !important;}
        [data-bs-theme="dark"] footer p, [data-bs-theme="dark"] footer a { color: #adb5bd !important; }

        .navbar-nav .nav-link { position: relative; padding-bottom: 5px; font-weight: 500; }
        .navbar-nav .nav-link::after { content: ''; position: absolute; width: 0; height: 3px; bottom: 0; left: 50%; background-color: var(--bs-primary); transition: all 0.3s ease-in-out; transform: translateX(-50%); border-radius: 5px; }
        .navbar-nav .nav-link:hover::after, .navbar-nav .nav-link.active::after { width: 100%; }
        .navbar-nav .nav-link.active { font-weight: 800 !important; color: var(--bs-primary) !important; }
        .custom-hover:hover { opacity: 1 !important; text-decoration: underline !important; color: var(--bs-primary) !important; }

        /* --- BANNIÈRE COOKIES --- */
        .cookie-overlay { position: fixed; bottom: -100%; left: 0; width: 100%; display: flex; justify-content: center; padding: 20px; z-index: 10000; transition: bottom 0.6s cubic-bezier(0.68, -0.55, 0.27, 1.55); pointer-events: none; }
        .cookie-overlay.show { bottom: 20px; pointer-events: auto; }
        .cookie-card { background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.5); border-radius: 24px; padding: 25px; max-width: 500px; display: flex; flex-wrap: wrap; align-items: center; gap: 20px; box-shadow: 0 15px 35px rgba(124, 58, 237, 0.15); }
        .cookie-icon { font-size: 2.5rem; color: #7c3aed; animation: rotateCookie 5s linear infinite; }
        .cookie-content { flex: 1; min-width: 200px; }
        .cookie-content h4 { margin: 0 0 5px 0; color: #1f2937; font-weight: 700; font-size: 1.1rem; }
        .cookie-content p { margin: 0; font-size: 0.9rem; color: #4b5563; line-height: 1.4; }
        .cookie-actions { display: flex; gap: 10px; width: 100%; margin-top: 5px; }
        .btn-cookie-accept { background: linear-gradient(135deg, #8b5cf6, #6d28d9); color: white; border: none; padding: 10px 25px; border-radius: 12px; font-weight: 600; cursor: pointer; flex: 2; transition: transform 0.2s; }
        .btn-cookie-refuse { background: #f3f4f6; color: #6b7280; border: none; padding: 10px 20px; border-radius: 12px; font-weight: 600; cursor: pointer; flex: 1; transition: background 0.2s; }
        .btn-cookie-accept:hover { transform: scale(1.03); }
        .btn-cookie-refuse:hover { background: #e5e7eb; }

        /* Cookie Dark Mode */
        [data-bs-theme="dark"] .cookie-card { background: rgba(33, 37, 41, 0.9); border-color: rgba(255, 255, 255, 0.1); box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5); }
        [data-bs-theme="dark"] .cookie-content h4 { color: #f8f9fa; }
        [data-bs-theme="dark"] .cookie-content p { color: #adb5bd; }
        [data-bs-theme="dark"] .btn-cookie-refuse { background: #343a40; color: #adb5bd; }
        [data-bs-theme="dark"] .btn-cookie-refuse:hover { background: #495057; }

        @keyframes rotateCookie { 0% { transform: rotate(0deg); } 10% { transform: rotate(15deg); } 20% { transform: rotate(-10deg); } 30% { transform: rotate(0deg); } }
    </style>
</head>

<body>

<div id="page-loader" class="position-fixed top-0 start-0 w-100 h-100 d-flex flex-column justify-content-center align-items-center">
    <div class="spinner-border text-primary mb-3" role="status" style="width: 4rem; height: 4rem; border-width: 0.3em;"></div>
    <h5 class="text-primary fw-bold">Chargement...</h5>
</div>

<nav class="navbar navbar-expand-lg bg-body-tertiary shadow-sm py-3 sticky-top">
    <div class="container-fluid">
        <a class="navbar-brand" href="{{ path('app_home') }}">
            <img src="{{ asset('images/FortIntervention.webp') }}" alt="Logo Fort Intervention" style="height: 45px; object-fit: contain;">
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">

            <ul class="navbar-nav me-auto gap-4 ms-lg-5">
                <li class="nav-item"><a class="nav-link {% if app.request.attributes.get('_route') == 'app_menuiserie' %}active{% endif %}" href="{{ path('app_menuiserie') }}">Menuiserie</a></li>
                <li class="nav-item"><a class="nav-link {% if app.request.attributes.get('_route') == 'app_service_vitrerie' %}active{% endif %}" href="{{ path('app_service_vitrerie') }}">Vitrerie</a></li>
                <li class="nav-item"><a class="nav-link {% if app.request.attributes.get('_route') == 'app_service_serrurerie' %}active{% endif %}" href="{{ path('app_service_serrurerie') }}">Serrurerie</a></li>
                <li class="nav-item"><a class="nav-link {% if app.request.attributes.get('_route') == 'app_service_plomberie' %}active{% endif %}" href="{{ path('app_service_plomberie') }}">Plomberie</a></li>
            </ul>

            <ul class="navbar-nav ms-auto align-items-center gap-2">

                <li class="nav-item me-2">
                    <button id="theme-toggle" class="btn btn-dark rounded-circle btn-theme-toggle shadow-sm">
                        <i id="theme-icon" class="fa-solid fa-moon text-white"></i>
                    </button>
                </li>

                <li class="nav-item">
                    <a href="{{ path('app_planning') }}" class="btn btn-primary fw-bold text-white shadow-sm d-flex align-items-center" style="height: 42px;">
                        <i class="fa-solid fa-calendar-plus me-2"></i> Planning / Réserver
                    </a>
                </li>

                {% if app.user %}

                    {# --- CLOCHE DE NOTIFICATION (Clients) --- #}
                    {% if not is_granted('ROLE_ADMIN') %}
                        {% set notifCount = render(controller('App\\Controller\\DashboardController::userNotificationBadge'))|striptags|trim %}
                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-outline-secondary rounded-circle shadow-sm d-flex align-items-center justify-content-center position-relative" href="{{ path('app_notifications') }}" style="width: 42px; height: 42px;">
                                <i class="fa-solid fa-bell"></i>
                                {% if notifCount > 0 %}
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light" style="font-size: 0.65rem;">
                                        {{ notifCount }}
                                    </span>
                                {% endif %}
                            </a>
                        </li>
                    {% endif %}

                    {# ==== AFFICHAGE ADMIN (Gestion + EasyAdmin) ==== #}
                    {% if is_granted('ROLE_ADMIN') %}
                        {% set adminCount = render(controller('App\\Controller\\DashboardController::adminNotificationBadge'))|striptags|trim %}

                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-primary rounded-circle shadow-sm d-flex align-items-center justify-content-center position-relative" href="{{ path('admin_demandes') }}" style="width: 42px; height: 42px;" title="Gestion des demandes">
                                <i class="fa-solid fa-gears text-white"></i>

                                {% if adminCount > 0 %}
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light" style="font-size: 0.65rem;">
                                        {{ adminCount }}
                                    </span>
                                {% endif %}
                            </a>
                        </li>

                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-dark rounded-circle shadow-sm d-flex align-items-center justify-content-center" href="{{ path('admin') }}" style="width: 42px; height: 42px;" title="Panel EasyAdmin">
                                <i class="fa-solid fa-user-shield text-white"></i>
                            </a>
                        </li>

                    {% endif %}

                    <li class="nav-item dropdown ms-2">
                        <a class="btn btn-outline-secondary rounded-pill shadow-sm d-flex align-items-center px-3 dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="height: 42px;">
                            {% if app.user.profilePicture %}
                                <img src="{{ asset('uploads/profiles/' ~ app.user.profilePicture) }}" alt="Profil" class="rounded-circle me-2" style="width: 24px; height: 24px; object-fit: cover;">
                            {% else %}
                                <i class="fa-solid fa-circle-user me-2"></i>
                            {% endif %}
                            <span class="fw-bold">{{ app.user.firstName }}</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                            <li><a class="dropdown-item" href="{{ path('app_profil') }}">Mon Profil</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_mes_rdv') }}">Mes Rendez-vous</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger fw-bold" href="{{ path('app_logout') }}">Déconnexion</a></li>
                        </ul>
                    </li>

                {% else %}
                    <li class="nav-item ms-lg-2">
                        <a class="btn btn-outline-secondary rounded-pill px-3 fw-bold" href="{{ path('app_login') }}">Connexion</a>
                    </li>
                    <li class="nav-item ms-lg-1">
                        <a class="btn btn-primary rounded-pill px-3 fw-bold shadow-sm" href="{{ path('app_register') }}">S'inscrire</a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<main class="w-100">
    {% block body %}{% endblock %}
</main>

<footer class="bg-dark text-white pt-5 pb-3 border-top mt-auto">
    <div class="container text-center">
        <img src="{{ asset('images/FortIntervention.webp') }}" alt="Logo" style="height: 60px; object-fit: contain; background-color: rgba(255,255,255,1); padding: 5px; border-radius: 8px;" class="mb-4">
        <div class="d-flex flex-wrap justify-content-center gap-4 mb-4">
            <a href="{{ path('app_about') }}" class="text-white text-decoration-none opacity-75 custom-hover">À propos de nous</a>
            <a href="{{ path('app_cgv') }}" class="text-white text-decoration-none opacity-75 custom-hover">Conditions Générales (CGV)</a>
            <a href="{{ path('app_mentions_legales') }}" class="text-white text-decoration-none opacity-75 custom-hover">Mentions légales</a>
            <a href="{{ path('app_cookies') }}" class="text-white text-decoration-none opacity-75 custom-hover">Politique des Cookies</a>
        </div>
        <p class="opacity-50 small m-0">&copy; {{ "now"|date("Y") }} Fort Intervention. Tous droits réservés.</p>
    </div>
</footer>

<div id="cookie-banner" class="cookie-overlay">
    <div class="cookie-card">
        <div class="cookie-icon">
            <i class="fa-solid fa-cookie-bite"></i>
        </div>
        <div class="cookie-content">
            <h4>Respect de votre vie privée</h4>
            <p>On utilise des cookies pour améliorer votre expérience et stocker vos réservations. C'est promis, on ne les mange pas ! 🍪</p>
        </div>
        <div class="cookie-actions">
            <button id="accept-cookies" class="btn-cookie-accept">Accepter</button>
            <button id="decline-cookies" class="btn-cookie-refuse">Refuser</button>
        </div>
    </div>
</div>

<script>
    document.addEventListener('turbo:before-fetch-request', () => { document.getElementById('page-loader').classList.add('is-loading'); });
    document.addEventListener('turbo:load', () => {
        setTimeout(() => { document.getElementById('page-loader').classList.remove('is-loading'); }, 100);

        // --- GESTION DU THEME SOMBRE ---
        const themeToggle = document.getElementById('theme-toggle');
        const themeIcon = document.getElementById('theme-icon');
        const htmlElement = document.documentElement;
        const savedTheme = localStorage.getItem('theme') || 'light';
        htmlElement.setAttribute('data-bs-theme', savedTheme);
        if (themeToggle && themeIcon) {
            if (savedTheme === 'dark') { themeIcon.classList.remove('fa-moon', 'text-white'); themeIcon.classList.add('fa-sun', 'text-warning'); }
            else { themeIcon.classList.remove('fa-sun', 'text-warning'); themeIcon.classList.add('fa-moon', 'text-white'); }
            themeToggle.onclick = (e) => {
                e.preventDefault();
                const currentTheme = htmlElement.getAttribute('data-bs-theme');
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                htmlElement.setAttribute('data-bs-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                if (newTheme === 'dark') { themeIcon.classList.remove('fa-moon', 'text-white'); themeIcon.classList.add('fa-sun', 'text-warning'); }
                else { themeIcon.classList.remove('fa-sun', 'text-warning'); themeIcon.classList.add('fa-moon', 'text-white'); }
            };
        }

        const banner = document.getElementById('cookie-banner');
        const acceptBtn = document.getElementById('accept-cookies');
        const declineBtn = document.getElementById('decline-cookies');

        if (banner && acceptBtn && declineBtn) {
            if (!localStorage.getItem('cookieConsent')) {
                setTimeout(() => {
                    banner.classList.add('show');
                }, 1500);
            }

            acceptBtn.onclick = () => {
                localStorage.setItem('cookieConsent', 'accepted');
                banner.classList.remove('show');
            };

            declineBtn.onclick = () => {
                localStorage.setItem('cookieConsent', 'declined');
                banner.classList.remove('show');
            };
        }
    });
</script>
</body>
</html>
